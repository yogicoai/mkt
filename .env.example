# ═══════════════════════════════════════════════════════════
#  광고 통합 대시보드 환경변수
#  키가 채워진 플랫폼만 대시보드에 자동으로 켜집니다.
# ═══════════════════════════════════════════════════════════

# ── 네이버 검색광고 (SA) ─────────────────────────────────
# manage.searchad.naver.com → 도구 → API 사용 관리
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=

# ── META (Facebook/Instagram) ───────────────────────────
# developers.facebook.com (앱) + business.facebook.com (토큰/계정)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=                 # 시스템 사용자 장기 토큰 (ads_read)
META_AD_ACCOUNT_YOGIBO=            # act_숫자 (또는 숫자만)
META_AD_ACCOUNT_SALLYFILL=         # act_숫자
# META_API_VERSION=v24.0
# META_PURCHASE_ACTION=omni_purchase   # 전환 기준 액션 (purchase / offsite_conversion.fc_purchase 등)

# ── Criteo ──────────────────────────────────────────────
# 앱/키 발급: partners.criteo.com → My Apps → Client Credentials → Create new key (.txt 다운로드, secret 1회만)
# 광고주 ID: GET https://api.criteo.com/2026-01/advertisers/me 응답 data[].id (또는 Management Center)
# ※ 발급한 앱을 광고주 계정에 authorize 해야 통계가 나옴 (안 하면 토큰OK·통계 빈값/403)
CRITEO_CLIENT_ID=
CRITEO_CLIENT_SECRET=
CRITEO_ADVERTISER_ID=
# CRITEO_RETAIL_ACCOUNT_ID=         # (선택) Retail Media 잔액 조회용
# CRITEO_API_VERSION=2026-01
# CRITEO_RETAIL_VERSION=2025-07

# ── 네이버 GFA (성과형 디스플레이) ──────────────────────
# ⚠️ 베타·파트너 승인 한정. developers.naver.com 앱 + 성과형광고 API 사용신청
# 잔액 조회 API 없음(콘솔 수동 확인)
GFA_ACCESS_TOKEN=                  # 네이버 로그인 OAuth2 access token
GFA_AD_ACCOUNT_NO=                 # adAccountNo

# ── AI 분석 (Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=                 # console.anthropic.com → API keys
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_PRICE_IN=5             # USD / 1M input tokens (예상 비용 계산용)
# ANTHROPIC_PRICE_OUT=25          # USD / 1M output tokens
# USD_KRW=1380

# ── MongoDB (추이 데이터 + KV 저장소: GFA·캠페인업로드·AI캐시) ──
# 서버리스(Vercel)에선 파일 저장이 불가 → 모든 영속 데이터는 여기에 저장됩니다.
MONGODB_URI=                       # mongodb+srv://... (yogibo 공유 클러스터 재사용)
# MONGO_DB=adboard                 # KV/daily_stats 저장 DB (기본 adboard)

# ── Cafe24 Analytics (yogiChat 토큰 재사용 · 읽기전용) ──
# 토큰 갱신은 yogiChat이 담당. 여기선 읽기만 (직접 refresh 금지).
CAFE24_MALL_ID=yogibo
CAFE24_TOKEN_URI=                  # yogiChat tokens 가 저장된 Mongo URI (보통 MONGODB_URI와 동일 클러스터)
CAFE24_TOKEN_DB=yogibo
CAFE24_TOKEN_COLLECTION=tokens

# ── 대시보드 접근 보호 (회사 공유용 Basic 인증) ──────────
# DASHBOARD_PASS 가 설정돼 있을 때만 인증 강제(미설정 시 누구나 접속 가능).
DASHBOARD_USER=yogibo
DASHBOARD_PASS=                    # 비워두면 인증 OFF. 공개배포 시 반드시 설정 권장.

# ── 카카오모먼트 (OpenAPI · 비즈니스 토큰) ──
# REST API 키 = developers.kakao.com 앱(387882) > 앱 키 / Client Secret = 카카오 로그인 > 보안
# 광고계정 ID = business.kakao.com/moment > 설정 > 광고계정 관리 (예: 167638 hub요기보코리아)
# 연결: 배포 후 카카오 탭의 "연결하기" → 1회 동의 → 비즈니스 토큰이 Mongo KV에 저장됨
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_AD_ACCOUNT_ID=
# KAKAO_SCOPE=moment_management    # 보고서 조회용 동의항목(기본값)
