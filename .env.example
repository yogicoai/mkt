# ═══════════════════════════════════════════════════════════
#  광고 통합 대시보드 환경변수
#  키가 채워진 플랫폼만 대시보드에 자동으로 켜집니다.
# ═══════════════════════════════════════════════════════════

# ── 네이버 검색광고 (SA) ─────────────────────────────────
# manage.searchad.naver.com → 도구 → API 사용 관리
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=

# ── META (Facebook/Instagram) ───────────────────────────
# developers.facebook.com (앱) + business.facebook.com (토큰/계정)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=                 # 시스템 사용자 장기 토큰 (ads_read)
META_AD_ACCOUNT_YOGIBO=            # act_숫자 (또는 숫자만)
META_AD_ACCOUNT_SALLYFILL=         # act_숫자
# META_API_VERSION=v24.0
# META_PURCHASE_ACTION=omni_purchase   # 전환 기준 액션 (purchase / offsite_conversion.fc_purchase 등)

# ── Criteo ──────────────────────────────────────────────
# 앱/키 발급: partners.criteo.com → My Apps → Client Credentials → Create new key (.txt 다운로드, secret 1회만)
# 광고주 ID: GET https://api.criteo.com/2026-01/advertisers/me 응답 data[].id (또는 Management Center)
# ※ 발급한 앱을 광고주 계정에 authorize 해야 통계가 나옴 (안 하면 토큰OK·통계 빈값/403)
CRITEO_CLIENT_ID=
CRITEO_CLIENT_SECRET=
CRITEO_ADVERTISER_ID=
# CRITEO_RETAIL_ACCOUNT_ID=         # (선택) Retail Media 잔액 조회용
# CRITEO_API_VERSION=2026-01
# CRITEO_RETAIL_VERSION=2025-07

# ── 네이버 GFA (성과형 디스플레이) ──────────────────────
# ⚠️ 베타·파트너 승인 한정. developers.naver.com 앱 + 성과형광고 API 사용신청
# 잔액 조회 API 없음(콘솔 수동 확인)
GFA_ACCESS_TOKEN=                  # 네이버 로그인 OAuth2 access token
GFA_AD_ACCOUNT_NO=                 # adAccountNo
